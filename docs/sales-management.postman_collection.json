              "path": ["api", "carts"],
              "query": [
                { "key": "_page", "value": "1" },
                { "key": "_size", "value": "10" },
                { "key": "_order", "value": "date desc" }
              ]
            }
          }
        },
        {
          "name": "Update Cart",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2026-05-12T00:00:00Z\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"productName\": \"Fjallraven Backpack\",\n      \"quantity\": 5\n    }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/carts/{{cartId}}", "host": ["{{baseUrl}}"], "path": ["api", "carts", "{{cartId}}"] }
          }
        },
        {
          "name": "Delete Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/carts/{{cartId}}", "host": ["{{baseUrl}}"], "path": ["api", "carts", "{{cartId}}"] }
          }
        }
      ]
    },
    {
      "name": "Sales",
      "item": [
        {
          "name": "Create Sale (qty < 4, no discount)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"saleNumber\": \"SALE-001\",\n  \"date\": \"2026-05-11T00:00:00Z\",\n  \"customerId\": \"{{userId}}\",\n  \"customerName\": \"John Doe\",\n  \"branchId\": \"00000000-0000-0000-0000-000000000001\",\n  \"branchName\": \"Branch SP\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"productName\": \"Fjallraven Backpack\",\n      \"quantity\": 2,\n      \"unitPrice\": 109.95\n    }\n  ]\n}"
            },
